# Copy to .env and adjust for local development
DATABASE_URL=postgresql://ptc:ptc_secret@localhost:5432/ptc_rewards
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Comma-separated origins for Next.js (default port 3000)
BACKEND_CORS_ORIGINS=http://localhost:3000

ENVIRONMENT=development
DEBUG=true

QR_SESSION_TTL_SECONDS=60
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_QR_SCAN=30/minute

# Number of trusted reverse proxies in front of the app. 0 = exposed directly
# (ignore X-Forwarded-For). Set to the real proxy depth (e.g. 1 behind Nginx)
# so per-client rate limiting uses the true client IP.
TRUSTED_PROXY_COUNT=0

# IANA timezone anchoring per-day earning limits (requires tzdata for non-UTC).
CAMPUS_TIMEZONE=UTC
