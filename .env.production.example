ENVIRONMENT=production
DEBUG=false

DATABASE_URL=postgresql://ptc:CHANGE_ME@db:5432/ptc_rewards
POSTGRES_USER=ptc
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ptc_rewards

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

BACKEND_CORS_ORIGINS=https://rewards.yourdomain.edu

QR_SESSION_TTL_SECONDS=60
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_QR_SCAN=30/minute

# Set to the number of reverse proxies in front of the API (e.g. 1 behind a
# single Nginx/ingress) so rate limiting keys on the real client IP.
TRUSTED_PROXY_COUNT=1

# Campus timezone for per-day earning limits (install the `tzdata` package).
CAMPUS_TIMEZONE=America/New_York
