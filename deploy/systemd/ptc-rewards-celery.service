[Unit]
Description=PTC Campus Rewards Celery Worker
After=network.target docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/ptc-rewards/backend
ExecStart=/usr/bin/docker compose -f docker-compose.prod.yml up -d celery_worker celery_beat
ExecStop=/usr/bin/docker compose -f docker-compose.prod.yml stop celery_worker celery_beat

[Install]
WantedBy=multi-user.target
